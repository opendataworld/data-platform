# opendataworld Caddyfile
# Serves the static landing and reverse-proxies metadata.open-data.world to OpenMetadata.
# Caddy auto-issues Let's Encrypt certs once DNS points here.

open-data.world, www.open-data.world {
    root * /var/www/landing
    file_server
    encode zstd gzip

    # Redirect www → apex
    @www host www.open-data.world
    redir @www https://open-data.world{uri} permanent
}

metadata.open-data.world {
    reverse_proxy localhost:8585
    encode zstd gzip
}
