# Open Data World - Caddyfile
# Wildcard DNS *.open-data.world points to this VPS

www.open-data.world {
    redir https://site.open-data.world
}

site.open-data.world {
    root * /var/www/landing
    file_server
    encode zstd gzip
}

docs.open-data.world {
    root * /var/www/docs
    file_server
    encode zstd gzip
}

trust.open-data.world {
    root * /var/www/trust
    file_server
    encode zstd gzip
}

api.open-data.world {
    reverse_proxy localhost:8000
    encode zstd gzip
}

flow.open-data.world {
    reverse_proxy localhost:7860
    encode zstd gzip
}

metadata.open-data.world {
    reverse_proxy localhost:8585
    encode zstd gzip
}
