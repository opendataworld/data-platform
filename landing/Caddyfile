# opendataworld Caddyfile
# Wildcard DNS *.open-data.world points to this VPS.
# Caddy auto-issues Let's Encrypt certs once DNS resolves here.

site.open-data.world {
    root * /var/www/landing
    file_server
    encode zstd gzip
}

trust.open-data.world {
    root * /var/www/trust
    file_server
    encode zstd gzip
}

metadata.open-data.world {
    reverse_proxy localhost:8585
    encode zstd gzip
}
