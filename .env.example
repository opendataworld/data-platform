# Copy to .env and fill in real values. .env is gitignored.

# ─── Identity (external Keycloak — not installed by this stack) ────────────────
KEYCLOAK_URL=https://auth.unboxd.cloud
KEYCLOAK_REALM=opendataworld
KEYCLOAK_ISSUER_URL=https://auth.unboxd.cloud/realms/opendataworld

# ─── Email / Notifications ─────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@platform.open-data.world

# ─── SSO (profile: sso) ────────────────────────────────────────────────────────
OAUTH2_PROXY_PORT=4180
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_REDIRECT_URL=https://platform.open-data.world/oauth2/callback

# ─── OpenMetadata (profile: catalog) ──────────────────────────────────────────
OPENMETADATA_PORT=8585
OPENMETADATA_OIDC_CLIENT_ID=openmetadata
OPENMETADATA_OIDC_CLIENT_SECRET=

# ─── Airbyte (profile: ingest) ────────────────────────────────────────────────
AIRBYTE_WEBAPP_PORT=8000
AIRBYTE_OIDC_CLIENT_ID=airbyte
AIRBYTE_OIDC_CLIENT_SECRET=

# ─── Zingg (profile: resolve) ─────────────────────────────────────────────────
# Runs as batch jobs; no user-facing auth needed.
ZINGG_SPARK_MEMORY=4g

# ─── Cube (profile: semantic) ─────────────────────────────────────────────────
CUBE_API_PORT=4000
CUBE_JWT_JWKS_URL=https://auth.unboxd.cloud/realms/opendataworld/protocol/openid-connect/certs

# ─── Superset (profile: viz) ──────────────────────────────────────────────────
SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=
SUPERSET_OIDC_CLIENT_ID=superset
SUPERSET_OIDC_CLIENT_SECRET=

# ─── Unomi (profile: cdp) ─────────────────────────────────────────────────────
UNOMI_PORT=8181
# Unomi is fronted by oauth2-proxy against Keycloak.
UNOMI_OAUTH2_CLIENT_ID=unomi
UNOMI_OAUTH2_CLIENT_SECRET=

# ─── SurrealDB (profile: store) ───────────────────────────────────────────────
SURREALDB_PORT=8000
SURREALDB_USER=root
SURREALDB_PASS=

# ─── PostgreSQL (profile: store) ──────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_USER=opendataworld
POSTGRES_PASSWORD=
POSTGRES_DB=platform

# ─── TerminusDB (profile: kg-edit) ────────────────────────────────────────────
TERMINUSDB_PORT=6363
TERMINUSDB_ADMIN_PASS=

# ─── GraphDB Free (profile: kg-pub) ───────────────────────────────────────────
GRAPHDB_PORT=7200
